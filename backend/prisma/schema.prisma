generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String   @default("")
  password_hash String
  role          String   @default("VIEWER")
  created_at    DateTime @default(now())
}

model SystemSettings {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model BettingPlayer {
  id                 String              @id @default(uuid())
  name               String              @unique
  is_active          Boolean             @default(true)
  default_bet_amount Float               @default(100.0)
  total_winnings     Float               @default(0.0)
  total_losses       Float               @default(0.0)
  net_balance        Float               @default(0.0)
  created_at         DateTime            @default(now())
  weekly_draws       WeeklyDrawEntry[]
  match_results      MatchResult[]
}

model IplMatch {
  id           String          @id @default(uuid())
  api_match_id String          @unique
  date         DateTime
  team_a_name  String
  team_b_name  String
  venue        String          @default("")
  status       String          @default("UPCOMING")
  bet_amount   Float           @default(100.0)
  created_at   DateTime        @default(now())
  results      MatchResult[]
}

// The weekly draw: positions assigned on Tuesday, valid Wed 12AM through Tue 11:59PM
model WeeklyDraw {
  id                String            @id @default(uuid())
  week_label        String            @unique  // e.g. "Apr 9 – Apr 15"
  week_start        DateTime                   // Wednesday
  week_end          DateTime                   // Tuesday
  payout_confirmed  Boolean           @default(false)
  payout_confirmed_at DateTime?
  created_at        DateTime          @default(now())
  entries           WeeklyDrawEntry[]
  results           MatchResult[]
}

// Each betting player's position assignment for the week
model WeeklyDrawEntry {
  id                String   @id @default(uuid())
  weekly_draw_id    String
  betting_player_id String
  team_a_position   Int      // 1-4
  team_b_position   Int      // 1-4
  created_at        DateTime @default(now())

  weekly_draw       WeeklyDraw    @relation(fields: [weekly_draw_id], references: [id])
  betting_player    BettingPlayer @relation(fields: [betting_player_id], references: [id])

  @@unique([weekly_draw_id, betting_player_id])
}

// Per-match results for each betting player (auto-created from weekly draw)
model MatchResult {
  id                String   @id @default(uuid())
  weekly_draw_id    String
  match_id          String
  betting_player_id String

  team_a_position   Int
  team_b_position   Int

  player_a_name     String   @default("")
  player_b_name     String   @default("")
  player_a_runs     Int      @default(0)
  player_b_runs     Int      @default(0)
  total_runs        Int      @default(0)

  is_winner         Boolean  @default(false)
  payout            Float    @default(0.0)

  payment_confirmed    Boolean  @default(false)
  payment_confirmed_at DateTime?

  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  weekly_draw       WeeklyDraw    @relation(fields: [weekly_draw_id], references: [id])
  match             IplMatch      @relation(fields: [match_id], references: [id])
  betting_player    BettingPlayer @relation(fields: [betting_player_id], references: [id])

  @@unique([match_id, betting_player_id])
}
